# Postgres connection string from Railway.
# Get it from your Railway project: Settings -> Variables -> DATABASE_URL.
# For local dev, you can use Railway's public connection string directly.
DATABASE_URL=postgresql://user:password@host:port/database

# Canonical site URL. Used as `metadataBase` for absolute OG / Twitter image
# URLs. Must point to a resolvable host (the apex `miniklaim.fun` has no DNS
# record yet, so use the `www` subdomain). Override in prod via Railway env.
NEXT_PUBLIC_SITE_URL=https://www.miniklaim.fun

# Contract addresses on Celo mainnet (chain id 42220).
NEXT_PUBLIC_MINIKLAIM_HEXES_ADDRESS=0x9945dDEAa9C52c3C4e667B71B698c4e4551F242B
NEXT_PUBLIC_MINIKLAIM_BADGES_ADDRESS=0x79c5d6365f447d1F707EA6d4bDE5D6A96f181cf7

# Server signer with CAPTURER_ROLE on Hexes and MINTER_ROLE on Badges.
# Hot key on Railway; rotate annually or on suspected leak.
SERVER_SIGNER_PRIVATE_KEY=0x...
